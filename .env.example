# UrbanChain backend configuration — copy to .env and fill with real values.
# NEVER commit the real .env file.

# --- Admin auth ---
URBANCHAIN_ADMIN_USERNAME=admin@example.gov.tr
URBANCHAIN_ADMIN_PASSWORD=change-this-password
URBANCHAIN_ADMIN_DEFAULT_ROLE=admin
URBANCHAIN_ADMIN_USERS_JSON=[{"username":"admin@example.gov.tr","password":"change-this-password","role":"admin","province_scope":"İstanbul"}]
URBANCHAIN_ADMIN_SESSION_HOURS=12
URBANCHAIN_ADMIN_LOGIN_MAX_ATTEMPTS=5
URBANCHAIN_ADMIN_LOGIN_WINDOW_MINUTES=15

# --- CORS / uploads ---
URBANCHAIN_ALLOW_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
URBANCHAIN_MAX_UPLOAD_BYTES=10485760
URBANCHAIN_PERCEPTUAL_HASH_DISTANCE_THRESHOLD=6

# --- IPFS (Pinata) ---
URBANCHAIN_IPFS_PROVIDER=pinata
URBANCHAIN_IPFS_PIN_URL=https://api.pinata.cloud/pinning/pinFileToIPFS
URBANCHAIN_IPFS_JWT=your-pinata-jwt-here
URBANCHAIN_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs
URBANCHAIN_IPFS_TIMEOUT_SECONDS=30

# --- SMTP (e-mail verification codes) ---
URBANCHAIN_SMTP_HOST=smtp.gmail.com
URBANCHAIN_SMTP_PORT=587
URBANCHAIN_SMTP_USERNAME=your-mail@gmail.com
URBANCHAIN_SMTP_PASSWORD=your-app-password
URBANCHAIN_SMTP_FROM_EMAIL=UrbanChain <your-mail@gmail.com>
URBANCHAIN_REQUIRE_SMTP=1
